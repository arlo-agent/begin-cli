# Begin CLI — Environment Variables
# Copy to .env and fill in your values. All are optional.

# ── Cardano ──────────────────────────────────────────
BLOCKFROST_API_KEY=              # Blockfrost API key (mainnet)
BLOCKFROST_API_KEY_TESTNET=      # Blockfrost API key (testnet)

# ── Solana ───────────────────────────────────────────
BEGIN_SOLANA_RPC=                # Custom Solana RPC (e.g. Helius, QuickNode)

# ── Bitcoin ──────────────────────────────────────────
# Uses Blockstream public API by default — no key needed

# ── EVM Networks ─────────────────────────────────────
BEGIN_ETH_RPC=                   # Ethereum mainnet RPC
BEGIN_BASE_RPC=                  # Base RPC
BEGIN_POLYGON_RPC=               # Polygon RPC
BEGIN_ARBITRUM_RPC=              # Arbitrum RPC
BEGIN_OPTIMISM_RPC=              # Optimism RPC
BEGIN_BSC_RPC=                   # BNB Chain RPC
BEGIN_AVALANCHE_RPC=             # Avalanche C-Chain RPC

# ── NMKR (NFT Minting) ──────────────────────────────
NMKR_API_KEY=                    # NMKR API key
NMKR_PROJECT_UID=                # NMKR project UID

# ── Wallet (Agent Mode) ─────────────────────────────
BEGIN_CLI_MNEMONIC=              # Wallet mnemonic (for non-interactive/agent use)
BEGIN_CLI_WALLET_PASSWORD=       # Wallet password (for non-interactive/agent use)
